        "showBorders": { "type": "boolean", "default": true },
        "showMeta": { "type": "boolean", "default": true },
        "showSearch": { "type": "boolean", "default": false },
        "openInNewTab": { "type": "boolean", "default": true }
    },
    "methods": {
        "refresh": {
            "description": "Listeyi yeniden yukler",
            "parameters": [],
            "body": "this.refresh();"
