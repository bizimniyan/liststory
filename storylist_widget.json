{
    "name": "StoryListWidget",
    "description": "Bir klasordeki SAC story'lerini tiklanabilir link olarak listeler",
    "newInstancePrefix": "StoryList",
    "eula": "",
    "vendor": "Custom",
    "license": "",
    "id": "com.custom.storylist",
    "version": "3.0.1",
    "icon": "",
    "webcomponents": [
        {
            "kind": "main",
            "tag": "custom-story-list",
            "url": "https://bizimniyan.github.io/liststory/main.js?v=300",
            "integrity": "",
            "ignoreIntegrity": true
        },
        {
            "kind": "builder",
            "tag": "custom-story-list-builder",
            "url": "https://bizimniyan.github.io/liststory/builder.js?v=300",
            "integrity": "",
            "ignoreIntegrity": true
        }
    ],
    "properties": {
        "title": { "type": "string", "default": "Story'ler" },
        "repositoryUrl": { "type": "string", "default": "https://dksac.eu10.analytics.cloud.sap/api/v1/filerepository/Resources?$filter=parentFolderResourceId%20eq%20%27034E0D52E49642EF8AEC9C9EB40DD7F4%27" },
        "sortBy": { "type": "string", "default": "none" },
        "textColor": { "type": "string", "default": "#0a6ed1" },
        "fontSize": { "type": "integer", "default": 14 },
        "fontWeight": { "type": "string", "default": "normal" },
